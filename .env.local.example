# Database Configuration untuk SPMT System
# Copy file ini ke .env.local dan sesuaikan dengan konfigurasi MySQL Anda

# Database Host (biasanya localhost)
DB_HOST=localhost

# Database User (biasanya root)
DB_USER=root

# Database Password (kosong jika tidak ada password)
DB_PASSWORD=

# Database Name (harus sama dengan yang dibuat)
DB_NAME=spmt_pelindo_revisi

# Database Port (biasanya 3306 untuk MySQL)
DB_PORT=3307

# Alternative: Full connection string
# DATABASE_URL=mysql://root:@localhost:3306/spmt_pelindo

# Catatan:
# 1. Ganti DB_PASSWORD dengan password MySQL Anda jika ada
# 2. Pastikan database 'spmt_pelindo' sudah dibuat
# 3. Jalankan setup-database.sql atau setup-database.bat/.sh
# 4. Restart aplikasi Next.js setelah mengubah konfigurasi

NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CLOUDFLARE_SECRET_KEY=

